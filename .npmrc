# Autorise les conflits peer-deps non-bloquants en pratique.
# Nécessaire pour @visx/* 3.12 qui n'a pas encore tagué React 19 dans
# ses peerDependencies (mais fonctionne sans souci). Sans ça, `npm ci`
# du Dockerfile EDH échoue avec ERESOLVE alors que `npm install` local
# passe.
legacy-peer-deps=true
